<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.student.Controller"
      spacing="0"
      prefWidth="750"
      prefHeight="600"
      styleClass="root-container">

    <!-- ── Header ── -->
    <HBox styleClass="header" alignment="CENTER">
        <Label text="🎓 Student Record Management System" styleClass="header-title"/>
    </HBox>

    <!-- ── Form Panel ── -->
    <VBox styleClass="form-panel" spacing="12">
        <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

        <Label text="Student Information" styleClass="section-label"/>

        <GridPane hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="90" prefWidth="90"/>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="90" prefWidth="90"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Row 0: Name -->
            <Label text="Name:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="txtName" promptText="Enter student name"
                       styleClass="form-input"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.columnSpan="3"/>

            <!-- Row 1: Course + Year -->
            <Label text="Course:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="txtCourse" promptText="e.g. BSIT, BSCS"
                       styleClass="form-input"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Year Level:" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <ChoiceBox fx:id="cbYear" prefWidth="160"
                       styleClass="form-input"
                       GridPane.columnIndex="3" GridPane.rowIndex="1"/>
        </GridPane>

        <!-- ── Buttons ── -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="6"/></padding>
            <Button text="➕  Add"    onAction="#addStudent"    styleClass="btn-add"    prefWidth="110"/>
            <Button text="✏️  Update" onAction="#updateStudent" styleClass="btn-update" prefWidth="110"/>
            <Button text="🗑️  Delete" onAction="#deleteStudent" styleClass="btn-delete" prefWidth="110"/>
            <Button text="✖  Clear"  onAction="#clearFields"   styleClass="btn-clear"  prefWidth="110"/>
        </HBox>

        <!-- Status label -->
        <Label fx:id="lblStatus" text="" styleClass="status-label"/>
    </VBox>

    <!-- ── Table ── -->
    <VBox VBox.vgrow="ALWAYS" styleClass="table-panel">
        <padding><Insets top="0" right="24" bottom="20" left="24"/></padding>

        <Label text="Student Records" styleClass="section-label">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>

        <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="student-table">
            <columns>
                <TableColumn fx:id="colId"     text="ID"         prefWidth="55"  style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colName"   text="Name"       prefWidth="230"/>
                <TableColumn fx:id="colCourse" text="Course"     prefWidth="200"/>
                <TableColumn fx:id="colYear"   text="Year Level" prefWidth="160" style="-fx-alignment: CENTER;"/>
            </columns>
            <placeholder><Label text="No student records found." style="-fx-text-fill: #aaa;"/></placeholder>
        </TableView>
    </VBox>
</VBox>
